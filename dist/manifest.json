{
  "manifest_version": 3,
  "name": "LifeLink Focus Hub",
  "version": "1.0.0",
  "description": "Spatial browsing intelligence and mindful focus tracking.",
  "permissions": [
    "tabs",
    "storage",
    "idle",
    "alarms"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
